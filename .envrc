# shellcheck shell=bash
watch_file shell.nix
nix_access_tokens_file=""
for candidate in "${NIX_ACCESS_TOKENS_FILE:-}" "${XDG_CONFIG_HOME:-$HOME/.config}/nix/access-tokens.conf" "/etc/nix/private/access-tokens.conf"; do
  if [ -n "$candidate" ] && [ -r "$candidate" ]; then
    nix_access_tokens_file="$candidate"
    break
  fi
done

if [ -n "$nix_access_tokens_file" ]; then
  case ":${NIX_USER_CONF_FILES:-}:" in
  *:"$nix_access_tokens_file":*) ;;
  *) export NIX_USER_CONF_FILES="$nix_access_tokens_file${NIX_USER_CONF_FILES:+:}$NIX_USER_CONF_FILES" ;;
  esac
fi

unset nix_access_tokens_file candidate
use flake
